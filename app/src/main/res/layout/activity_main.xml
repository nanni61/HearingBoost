<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- ── Header ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingBottom="16dp"
            android:paddingTop="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HearingBoost"
                android:textColor="@color/accent_orange"
                android:textSize="26sp"
                android:textStyle="bold"
                android:fontFamily="monospace" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Amplificatore vocale adattivo"
                android:textColor="@color/text_dim"
                android:textSize="12sp"
                android:paddingTop="2dp" />
        </LinearLayout>

        <!-- ── Status ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingBottom="20dp">

            <ImageView
                android:id="@+id/statusDot"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:src="@drawable/dot_idle"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="In pausa"
                android:textColor="@color/text_dim"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- ═══════════════════════════════════════ -->
        <!-- AMPLIFICAZIONE -->
        <!-- ═══════════════════════════════════════ -->

        <TextView style="@style/SectionLabel" android:text="AMPLIFICAZIONE" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Sinistra" android:textColor="@color/text_label" android:textSize="11sp"
            android:paddingBottom="4dp" />

        <LinearLayout style="@style/SliderRow">
            <SeekBar android:id="@+id/seekGainL" style="@style/Slider"
                android:progressTint="@color/accent_blue" android:thumbTint="@color/accent_blue" />
            <TextView android:id="@+id/tvGainLValue" style="@style/SliderValue"
                android:textColor="@color/accent_blue" />
        </LinearLayout>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Destra" android:textColor="@color/text_label" android:textSize="11sp"
            android:paddingBottom="4dp" android:paddingTop="6dp" />

        <LinearLayout style="@style/SliderRow">
            <SeekBar android:id="@+id/seekGainR" style="@style/Slider"
                android:progressTint="@color/accent_blue_r" android:thumbTint="@color/accent_blue_r" />
            <TextView android:id="@+id/tvGainRValue" style="@style/SliderValue"
                android:textColor="@color/accent_blue_r" />
        </LinearLayout>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="0% · 100% · 200% · 300% · 400% · 500%"
            android:textColor="@color/text_dim" android:textSize="9sp" android:paddingBottom="16dp" />

        <View style="@style/Divider" />

        <!-- ═══════════════════════════════════════ -->
        <!-- EFFETTI HARDWARE -->
        <!-- ═══════════════════════════════════════ -->

        <TextView style="@style/SectionLabel" android:text="EFFETTI HARDWARE" />

        <!-- AEC -->
        <LinearLayout android:id="@+id/rowAec" style="@style/CardRow" android:layout_marginBottom="10dp">
            <LinearLayout style="@style/CardTextBlock">
                <TextView style="@style/CardTitle" android:text="Soppressore Eco (AEC)" />
                <TextView style="@style/CardSubtitle" android:text="Elimina l'eco acustico dalle cuffie" />
            </LinearLayout>
            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchAec"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:checked="true" />
        </LinearLayout>

        <!-- AGC -->
        <LinearLayout android:id="@+id/rowAgc" style="@style/CardRow" android:layout_marginBottom="16dp">
            <LinearLayout style="@style/CardTextBlock">
                <TextView style="@style/CardTitle" android:text="Controllo Guadagno Auto (AGC)" />
                <TextView style="@style/CardSubtitle" android:text="Normalizza il volume del parlato" />
            </LinearLayout>
            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchAgc"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:checked="true" />
        </LinearLayout>

        <View style="@style/Divider" />

        <!-- ═══════════════════════════════════════ -->
        <!-- FILTRI -->
        <!-- ═══════════════════════════════════════ -->

        <TextView style="@style/SectionLabel" android:text="FILTRI" />

        <!-- EQ Vocale -->
        <LinearLayout style="@style/CardRow" android:layout_marginBottom="10dp">
            <LinearLayout style="@style/CardTextBlock">
                <TextView style="@style/CardTitle" android:text="EQ Vocale" />
                <TextView style="@style/CardSubtitle" android:text="Passa-banda 300 Hz – 3.4 kHz" />
            </LinearLayout>
            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchVoiceEq"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:checked="true" />
        </LinearLayout>

        <!-- High-Pass -->
        <LinearLayout style="@style/CardCol" android:layout_marginBottom="10dp">
            <LinearLayout style="@style/CardRowInner">
                <LinearLayout style="@style/CardTextBlock">
                    <TextView style="@style/CardTitle" android:text="Filtro Passa-Alto (HP)" />
                    <TextView style="@style/CardSubtitle" android:text="Taglia frequenze sotto la soglia" />
                </LinearLayout>
                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchHp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content" />
            </LinearLayout>
            <LinearLayout style="@style/SliderRow">
                <SeekBar android:id="@+id/seekHp" style="@style/Slider"
                    android:progressTint="@color/accent_orange" android:thumbTint="@color/accent_orange" />
                <TextView android:id="@+id/tvHpValue" style="@style/SliderValueSm"
                    android:textColor="@color/accent_orange" />
            </LinearLayout>
        </LinearLayout>

        <!-- Low-Pass -->
        <LinearLayout style="@style/CardCol" android:layout_marginBottom="16dp">
            <LinearLayout style="@style/CardRowInner">
                <LinearLayout style="@style/CardTextBlock">
                    <TextView style="@style/CardTitle" android:text="Filtro Passa-Basso (LP)" />
                    <TextView style="@style/CardSubtitle" android:text="Taglia frequenze sopra la soglia" />
                </LinearLayout>
                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchLp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content" />
            </LinearLayout>
            <LinearLayout style="@style/SliderRow">
                <SeekBar android:id="@+id/seekLp" style="@style/Slider"
                    android:progressTint="@color/accent_teal" android:thumbTint="@color/accent_teal" />
                <TextView android:id="@+id/tvLpValue" style="@style/SliderValueSm"
                    android:textColor="@color/accent_teal" />
            </LinearLayout>
        </LinearLayout>

        <View style="@style/Divider" />

        <!-- ═══════════════════════════════════════ -->
        <!-- MIGLIORAMENTO VOCALE -->
        <!-- ═══════════════════════════════════════ -->

        <TextView style="@style/SectionLabel" android:text="MIGLIORAMENTO VOCALE" />

        <!-- Pre-enfasi consonanti -->
        <LinearLayout style="@style/CardCol" android:layout_marginBottom="10dp">
            <LinearLayout style="@style/CardRowInner">
                <LinearLayout style="@style/CardTextBlock">
                    <TextView style="@style/CardTitle" android:text="Pre-enfasi Consonanti" />
                    <TextView style="@style/CardSubtitle" android:text="Boost alti 2–4 kHz per intelligibilità" />
                </LinearLayout>
                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchPreEmph"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:checked="true" />
            </LinearLayout>
            <LinearLayout style="@style/SliderRow">
                <SeekBar android:id="@+id/seekPreEmph" style="@style/Slider"
                    android:progressTint="@color/accent_yellow" android:thumbTint="@color/accent_yellow" />
                <TextView android:id="@+id/tvPreEmphValue" style="@style/SliderValueSm"
                    android:textColor="@color/accent_yellow" />
            </LinearLayout>
        </LinearLayout>

        <!-- Compressore dinamico -->
        <LinearLayout style="@style/CardCol" android:layout_marginBottom="16dp">
            <LinearLayout style="@style/CardRowInner">
                <LinearLayout style="@style/CardTextBlock">
                    <TextView style="@style/CardTitle" android:text="Compressore Dinamico" />
                    <TextView style="@style/CardSubtitle" android:text="Livella il volume del parlato" />
                </LinearLayout>
                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchComp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:checked="true" />
            </LinearLayout>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Soglia" android:textColor="@color/text_label"
                android:textSize="11sp" android:paddingTop="8dp" android:paddingBottom="2dp" />
            <LinearLayout style="@style/SliderRow">
                <SeekBar android:id="@+id/seekCompThresh" style="@style/Slider"
                    android:progressTint="@color/accent_orange" android:thumbTint="@color/accent_orange" />
                <TextView android:id="@+id/tvCompThreshValue" style="@style/SliderValueSm"
                    android:textColor="@color/accent_orange" />
            </LinearLayout>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Rapporto" android:textColor="@color/text_label"
                android:textSize="11sp" android:paddingTop="6dp" android:paddingBottom="2dp" />
            <LinearLayout style="@style/SliderRow">
                <SeekBar android:id="@+id/seekCompRatio" style="@style/Slider"
                    android:progressTint="@color/accent_blue" android:thumbTint="@color/accent_blue" />
                <TextView android:id="@+id/tvCompRatioValue" style="@style/SliderValueSm"
                    android:textColor="@color/accent_blue" />
            </LinearLayout>
        </LinearLayout>

        <View style="@style/Divider" />

        <!-- ═══════════════════════════════════════ -->
        <!-- GATE E RUMORE -->
        <!-- ═══════════════════════════════════════ -->

        <TextView style="@style/SectionLabel" android:text="GATE E RUMORE" />

        <!-- dB Gate -->
        <LinearLayout style="@style/CardCol" android:layout_marginBottom="10dp">
            <LinearLayout style="@style/CardRowInner">
                <LinearLayout style="@style/CardTextBlock">
                    <TextView style="@style/CardTitle" android:text="Gate dB" />
                    <TextView style="@style/CardSubtitle" android:text="Silenzia segnali sotto la soglia" />
                </LinearLayout>
                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchGate"
                    android:layout_width="wrap_content" android:layout_height="wrap_content" />
            </LinearLayout>
            <LinearLayout style="@style/SliderRow">
                <SeekBar android:id="@+id/seekGate" style="@style/Slider"
                    android:progressTint="@color/accent_yellow" android:thumbTint="@color/accent_yellow" />
                <TextView android:id="@+id/tvGateValue" style="@style/SliderValueSm"
                    android:textColor="@color/accent_yellow" />
            </LinearLayout>
        </LinearLayout>

        <!-- Noise Reduction -->
        <LinearLayout style="@style/CardCol" android:layout_marginBottom="24dp">
            <TextView style="@style/CardTitle" android:text="Riduzione Rumore" android:paddingBottom="2dp" />
            <TextView style="@style/CardSubtitle" android:text="Gate adattivo su RMS" android:paddingBottom="8dp" />
            <LinearLayout style="@style/SliderRow">
                <SeekBar android:id="@+id/seekNoise" style="@style/Slider"
                    android:progressTint="@color/accent_orange" android:thumbTint="@color/accent_orange" />
                <TextView android:id="@+id/tvNoiseValue" style="@style/SliderValueSm"
                    android:textColor="@color/accent_orange" />
            </LinearLayout>
        </LinearLayout>

        <View style="@style/Divider" />

        <!-- ── Start/Stop ── -->
        <Button
            android:id="@+id/btnToggle"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="▶ Avvia"
            android:textSize="17sp"
            android:textColor="@color/white"
            android:backgroundTint="@color/start_green"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚠ Valori oltre 100% possono causare distorsione. Inizia dal livello più basso."
            android:textColor="@color/text_dim"
            android:textSize="10sp"
            android:gravity="center"
            android:paddingBottom="16dp" />

    </LinearLayout>
</ScrollView>
