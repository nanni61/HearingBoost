<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- ── Header ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingBottom="32dp"
            android:paddingTop="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HearingBoost"
                android:textColor="@color/accent_orange"
                android:textSize="28sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:fontFamily="monospace" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Amplificatore vocale adattivo"
                android:textColor="@color/text_dim"
                android:textSize="13sp"
                android:paddingTop="4dp" />
        </LinearLayout>

        <!-- ── Status row ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingBottom="32dp">

            <ImageView
                android:id="@+id/statusDot"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/dot_idle"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="In pausa"
                android:textColor="@color/text_dim"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- ── GAIN LEFT ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AMPLIFICAZIONE SINISTRA"
            android:textColor="@color/text_label"
            android:textSize="11sp"
            android:letterSpacing="0.12"
            android:paddingBottom="6dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="8dp">

            <SeekBar
                android:id="@+id/seekGainL"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:progressTint="@color/accent_blue"
                android:thumbTint="@color/accent_blue" />

            <TextView
                android:id="@+id/tvGainLValue"
                android:layout_width="56dp"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:textColor="@color/accent_blue"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="monospace" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="0%  ·  100%  ·  200%  ·  300%  ·  400%  ·  500%"
            android:textColor="@color/text_dim"
            android:textSize="10sp"
            android:paddingBottom="24dp" />

        <!-- ── GAIN RIGHT ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AMPLIFICAZIONE DESTRA"
            android:textColor="@color/text_label"
            android:textSize="11sp"
            android:letterSpacing="0.12"
            android:paddingBottom="6dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="8dp">

            <SeekBar
                android:id="@+id/seekGainR"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:progressTint="@color/accent_blue_r"
                android:thumbTint="@color/accent_blue_r" />

            <TextView
                android:id="@+id/tvGainRValue"
                android:layout_width="56dp"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:textColor="@color/accent_blue_r"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="monospace" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="0%  ·  100%  ·  200%  ·  300%"
            android:textColor="@color/text_dim"
            android:textSize="10sp"
            android:paddingBottom="24dp" />

        <!-- ── Divider ── -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"
            android:layout_marginBottom="24dp" />

        <!-- ── NOISE REDUCTION ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RIDUZIONE RUMORE"
            android:textColor="@color/text_label"
            android:textSize="11sp"
            android:letterSpacing="0.12"
            android:paddingBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Filtra rumori di fondo, mantiene la voce umana (300–3400 Hz)"
            android:textColor="@color/text_dim"
            android:textSize="11sp"
            android:paddingBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="8dp">

            <SeekBar
                android:id="@+id/seekNoise"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:progressTint="@color/accent_orange"
                android:thumbTint="@color/accent_orange" />

            <TextView
                android:id="@+id/tvNoiseValue"
                android:layout_width="96dp"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:textColor="@color/accent_orange"
                android:textSize="13sp"
                android:fontFamily="monospace" />
        </LinearLayout>

        <!-- ── Info chip: voice band ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/chip_bg"
            android:padding="12dp"
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎙️"
                android:textSize="18sp"
                android:layout_marginEnd="10dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Banda vocale attiva: 300 Hz – 3.4 kHz\nEqualizzazione passa-banda per voce umana"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:lineSpacingExtra="2dp" />
        </LinearLayout>

        <!-- ── Divider ── -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"
            android:layout_marginBottom="32dp" />

        <!-- ── Start/Stop button ── -->
        <Button
            android:id="@+id/btnToggle"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="▶ Avvia"
            android:textSize="18sp"
            android:textColor="@color/white"
            android:backgroundTint="@color/start_green"
            android:layout_marginBottom="16dp" />

        <!-- ── Warning ── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚠ Valori oltre 100% possono causare distorsione o fastidio. Inizia sempre dal livello più basso."
            android:textColor="@color/text_dim"
            android:textSize="11sp"
            android:gravity="center"
            android:paddingBottom="16dp" />

    </LinearLayout>
</ScrollView>
